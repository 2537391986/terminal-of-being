];

// 工具:随机范围取值
function rollRange(min, max) {
  return min + Math.random() * (max - min);
}

// 从词缀池中随机选一条,按 level 缩放
export function rollAffix(pool, level) {
  const affix = pool[Math.floor(Math.random() * pool.length)];
  const result = { id: affix.id, name: affix.name, stats: {} };
  const scale = 1 + (level - 1) * 0.08; // 每级 +8%
  for (const [key, [min, max]] of Object.entries(affix.stats)) {
    result.stats[key] = parseFloat((rollRange(min, max) * scale).toFixed(3));
  }
  return result;
}
