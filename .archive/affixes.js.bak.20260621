  { id: 'pf_sharp',    name: '锋利的',     stats: { atk: [2, 5] } },
  { id: 'pf_swift',    name: '迅捷的',     stats: { aspd: [0.05, 0.15] } },
  { id: 'pf_keen',     name: '敏锐的',     stats: { crit: [0.02, 0.06] } },
  { id: 'pf_vital',    name: '生命力的',   stats: { maxHp: [15, 40] } },
  { id: 'pf_lucky',    name: '偶然的',     stats: { luck: [2, 8] } },
  { id: 'pf_greedy',   name: '积聚的',     stats: { goldGain: [0.05, 0.15] } },
  { id: 'pf_wise',     name: '经验主义的', stats: { expGain: [0.05, 0.15] } },
  { id: 'pf_hungry',   name: '渴求的',     stats: { lifesteal: [0.02, 0.06] } },
