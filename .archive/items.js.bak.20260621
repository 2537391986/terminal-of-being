// 按 slot 查询可用模板
export function getTemplatesBySlot(slot) {
  return ITEM_TEMPLATES.filter(t => t.slot === slot);
}

// 随机选一个模板
export function randomTemplate() {
  return ITEM_TEMPLATES[Math.floor(Math.random() * ITEM_TEMPLATES.length)];
}
