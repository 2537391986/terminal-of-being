// js/data/items.js
// 装备模板(MVP 12 件)
// 每件 = 基础属性 + 概念绑定 + 特殊效果描述

import { CONCEPTS } from './concepts.js';

// 辅助:按术语查概念
function findConcept(term) {
  return CONCEPTS.find(c => c.term === term) || { term, school: '未知', field: 'unknown', summary: '' };
}

