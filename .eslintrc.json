{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "performance": "readonly",
    "requestAnimationFrame": "readonly",
    "localStorage": "readonly",
    "setInterval": "readonly",
    "clearInterval": "readonly",
    "setTimeout": "readonly",
    "console": "readonly",
    "document": "readonly",
    "window": "readonly",
    "Date": "readonly",
    "Math": "readonly",
    "Set": "readonly",
    "Map": "readonly",
    "location": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-redeclare": "error",
    "no-dupe-imports": "error",
    "no-constant-condition": "warn",
    "no-debugger": "error",
    "no-console": "off",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-var": "error",
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.name='confirm']",
        "message": "confirm() is banned — use a custom modal instead."
      }
    ]
  }
}
